# Copy this to .env and fill in your values.
# NOTE: this file is for local dev only. The submitted Docker image reads
# FIREWORKS_API_KEY / FIREWORKS_BASE_URL / ALLOWED_MODELS purely from the
# environment — the harness injects real values at evaluation time, and no
# .env is bundled into the image.

# --- Fireworks AI ---
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Harness-injected at evaluation time. Local dev default points at the real
# Fireworks endpoint; the harness overrides this with its metering/judging
# proxy URL at eval time — all calls must go through whatever URL is set here.
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated list of allowed Fireworks model IDs, published by the harness
# on launch day. Leave unset for local dev — REMOTE_MODEL_FAST/REMOTE_MODEL_STRONG
# below are used as a fallback in that case. Set it locally only to test the
# dynamic fast/strong model selection in agent/config.py.
ALLOWED_MODELS=

# Local dev fallback only — ignored whenever ALLOWED_MODELS is set.
REMOTE_MODEL_FAST=accounts/fireworks/models/glm-5p1
REMOTE_MODEL_STRONG=accounts/fireworks/models/gpt-oss-120b

REMOTE_TIMEOUT=45

# --- Local model (must be pulled in Ollama) ---
LOCAL_MODEL=phi3:mini
LOCAL_BASE_URL=http://localhost:11434
LOCAL_TIMEOUT=60

# --- Routing thresholds (tune with eval.py) ---
# Complexity score <= COMPLEXITY_LOW  → always local
# Complexity score >= COMPLEXITY_HIGH → always remote
# Between the two                     → cascade (try local, escalate if low confidence)
COMPLEXITY_LOW=0.30
COMPLEXITY_HIGH=0.65
CONFIDENCE_THRESHOLD=0.60

# Max tokens the remote model may produce per call
REMOTE_MAX_TOKENS=1024
